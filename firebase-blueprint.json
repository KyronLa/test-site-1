{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "A research peptide or compound available for purchase.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "The name of the peptide." },
        "price": { "type": "number", "description": "The price in USD." },
        "category": { "type": "string", "description": "The category of the compound." },
        "image": { "type": "string", "description": "URL to the product image." },
        "description": { "type": "string", "description": "Detailed research description." },
        "purity": { "type": "string", "description": "Guaranteed purity level (e.g., 99%+)." },
        "size": { "type": "string", "description": "Vial size (e.g., 5mg)." },
        "quantityImages": {
          "type": "object",
          "properties": {
            "1": { "type": "string" },
            "2": { "type": "string" },
            "3": { "type": "string" }
          }
        },
        "stock": { "type": "integer", "description": "Current inventory count.", "default": 0 },
        "inStock": { "type": "boolean", "description": "Whether the product is currently available for purchase.", "default": false },
        "lowStockThreshold": { "type": "integer", "description": "The quantity at which a low stock warning is triggered.", "default": 5 },
        "isArchived": { "type": "boolean", "description": "Whether the product is archived and hidden from the storefront.", "default": false }
      },
      "required": ["name", "price", "category", "image"]
    },
    "User": {
      "title": "User",
      "description": "A customer account.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "phone": { "type": "string" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLogin": { "type": "string", "format": "date-time" },
        "addresses": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "street": { "type": "string" },
              "city": { "type": "string" },
              "state": { "type": "string" },
              "zip": { "type": "string" },
              "isDefault": { "type": "boolean" }
            }
          } 
        },
        "rewardPoints": { "type": "number", "description": "Loyalty points balance." }
      },
      "required": ["email", "firstName", "lastName"]
    },
    "Order": {
      "title": "Order",
      "description": "A purchase record.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array", "items": { "type": "object" } },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "items", "total", "status", "createdAt"]
    },
    "COARequest": {
      "title": "COARequest",
      "description": "A request for a Certificate of Analysis.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "product": { "type": "string", "description": "Product name or batch ID." },
        "message": { "type": "string", "description": "Optional notes." },
        "status": { "type": "string", "enum": ["pending", "processed"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["email", "product", "status", "createdAt"]
    },
    "SiteSettings": {
      "title": "SiteSettings",
      "description": "Global website configuration and features.",
      "type": "object",
      "properties": {
        "countdownActive": { "type": "boolean", "description": "Whether the countdown timer is active." },
        "countdownText": { "type": "string", "description": "Custom text to display with the timer." },
        "countdownTarget": { "type": "string", "format": "date-time", "description": "The target date and time for the countdown." }
      }
    },
    "AffiliateApplication": {
      "title": "AffiliateApplication",
      "description": "An application to join the Research Affiliate program.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "fullName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "socialHandle": { "type": "string", "description": "Instagram and/or TikTok handle" },
        "followerCount": { "type": "string", "enum": ["Under 1K", "1K–10K", "10K–50K", "50K+"] },
        "niche": { "type": "string", "enum": ["Fitness", "Bodybuilding", "Biohacking", "General Wellness", "Other"] },
        "avgViews": { "type": "string", "description": "Average Views Per Post" },
        "usesPeptides": { "type": "string", "enum": ["Yes", "No"] },
        "whyPartner": { "type": "string", "description": "Why do you want to partner with Eclipse Research?", "maxLength": 300 },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "socialHandle", "followerCount", "niche", "avgViews", "usesPeptides", "whyPartner", "status", "createdAt"]
    },
    "PromoCode": {
      "title": "PromoCode",
      "description": "A promotional discount code.",
      "type": "object",
      "properties": {
        "code": { "type": "string", "description": "The alphanumeric code (e.g., RESEARCH20)." },
        "discount": { "type": "number", "description": "The discount percentage (e.g., 20 for 20%)." },
        "isActive": { "type": "boolean", "description": "Whether the code is currently active." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["code", "discount", "isActive", "createdAt"]
    }
  },
  "firestore": {
    "/products": { "schema": "Product", "description": "Collection of available research compounds." },
    "/users": { "schema": "User", "description": "User profile data." },
    "/orders": { "schema": "Order", "description": "Customer order history." },
    "/coa_requests": { "schema": "COARequest", "description": "Requests for Certificates of Analysis." },
    "/settings": { "schema": "SiteSettings", "description": "Global site configuration." },
    "/affiliate_applications": { "schema": "AffiliateApplication", "description": "Applications for the affiliate program." },
    "/promo_codes": { "schema": "PromoCode", "description": "Active and inactive promotional codes." }
  }
}
