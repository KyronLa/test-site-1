rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: products
    // Fields: name, price, category, image, description, purity, size
    //
    // Collection: users
    // Fields: email, firstName, lastName, phone, displayName, role, createdAt, lastLogin
    //
    // Collection: orders
    // Fields: userId, items, total, status, createdAt
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && 
        (request.auth.token.email in ["info@eclipseresearch.shop", "kyron.laskosky2@gmail.com"] && request.auth.token.email_verified == true);
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.price is number && data.price >= 0 &&
             data.category is string &&
             data.image is string &&
             (!('stock' in data) || data.stock is int) &&
             (!('inStock' in data) || data.inStock is bool) &&
             (!('lowStockThreshold' in data) || data.lowStockThreshold is int) &&
             (!('isArchived' in data) || data.isArchived is bool);
    }

    function isValidUser(data) {
      return data.email is string &&
             data.firstName is string && data.firstName.size() > 0 &&
             data.lastName is string && data.lastName.size() > 0 &&
             (!('phone' in data) || data.phone == null || data.phone is string) &&
             (!('addresses' in data) || data.addresses is list) &&
             (!('rewardPoints' in data) || data.rewardPoints is number);
    }

    function isValidSettings(data) {
      return (!('countdownActive' in data) || data.countdownActive is bool) &&
             (!('countdownText' in data) || data.countdownText is string) &&
             (!('countdownTarget' in data) || data.countdownTarget is string);
    }

    function isValidAffiliateApplication(data) {
      return data.email is string &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.socialHandle is string && data.socialHandle.size() > 0 &&
             data.followerCount in ["Under 1K", "1K–10K", "10K–50K", "50K+"] &&
             data.niche in ["Fitness", "Bodybuilding", "Biohacking", "General Wellness", "Other"] &&
             data.avgViews is string &&
             data.usesPeptides in ["Yes", "No"] &&
             data.whyPartner is string && data.whyPartner.size() <= 300 &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    function isValidPromoCode(data) {
      return data.code is string && data.code.size() > 0 &&
             data.discount is number && data.discount >= 0 && data.discount <= 100 &&
             data.isActive is bool;
    }

    // Rules
    match /products/{productId} {
      allow read: if true; // Products are publicly viewable
      allow create, update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true; // Settings are publicly readable
      allow create, update: if isAdmin() && isValidSettings(request.resource.data);
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data) &&
                    (!('role' in request.resource.data) || request.resource.data.role == resource.data.role);
      allow delete: if isAdmin();
    }

    match /orders/{orderId} {
      // Allow read if user is owner, admin, or if they are tracking a guest order (checked via ID)
      // Note: In a production app, you'd ideally use a query with email filter to restrict this further.
      allow read: if (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin())) || 
                     (resource.data.shippingInfo.email == request.auth.token.email) ||
                     (!isAuthenticated()); // Allow guest tracking via ID (Security by Obscurity)
      
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid) || 
                       (!isAuthenticated()); // Allow guest checkout
      
      allow update: if isAdmin();
      
      allow delete: if (isAuthenticated() && resource.data.userId == request.auth.uid && resource.data.status == 'pending') || isAdmin();
    }

    match /coa_requests/{requestId} {
      allow create: if true; // Anyone can request a COA
      allow read, update, delete: if isAdmin();
    }

    match /affiliate_applications/{applicationId} {
      allow create: if isValidAffiliateApplication(request.resource.data);
      allow read, update, delete: if isAdmin();
    }

    match /promo_codes/{promoId} {
      allow read: if true; // Publicly readable for validation during checkout
      allow create, update: if isAdmin() && isValidPromoCode(request.resource.data);
      allow delete: if isAdmin();
    }
  }
}
